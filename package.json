{
  "name": "@elvatis_com/openclaw-gpu-bridge",
  "version": "0.2.1",
  "description": "OpenClaw plugin - Remote GPU compute via FastAPI microservice (BERTScore, embeddings)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "!dist/**/*.test.*",
    "gpu-service/",
    "!gpu-service/__pycache__/",
    "!gpu-service/**/__pycache__/",
    "!gpu-service/tests/",
    "!gpu-service/pytest.ini",
    "!gpu-service/.pytest_cache/",
    "!gpu-service/requirements-dev.txt",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:python": "cd gpu-service && python -m pytest tests/ -v",
    "test:all": "npm test && npm run test:python",
    "prepublishOnly": "npm run build",
    "test:watch": "vitest"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "gpu",
    "bert-score",
    "embeddings",
    "ml",
    "remote-compute",
    "sentence-transformers",
    "roberta"
  ],
  "author": "Elvatis <emre.kohler@elvatis.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elvatis/openclaw-gpu-bridge.git"
  },
  "homepage": "https://github.com/elvatis/openclaw-gpu-bridge#readme",
  "bugs": {
    "url": "https://github.com/elvatis/openclaw-gpu-bridge/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "overrides": {
    "test-exclude": "^7.0.1"
  }
}
